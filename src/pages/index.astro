---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Menu from '../components/Menu.astro';
import Info from '../components/Info.astro';
import Cta from '../components/Cta.astro';
import Footer from '../components/Footer.astro';

import { siteContent } from '../contents/siteContent';
---

<BaseLayout title={siteContent.site.title} description={siteContent.site.description}>
	<Header content={siteContent.header} />
	<Hero content={siteContent.hero} />
	<Menu content={siteContent.menu} />
	<Info content={siteContent.info} />
	<Cta content={siteContent.cta} />
	<Footer content={siteContent.footer} />
</BaseLayout>